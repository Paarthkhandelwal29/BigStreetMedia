# Big Street Media — environment template.
# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# The public marketing site runs WITHOUT any of these (the CMS degrades to
# empty reads). They are required only for the /admin portal to work.

# --- Admin portal login (required for /admin) ---
# ADMIN_PASSWORD: the password typed at /admin/login.
# ADMIN_SESSION_SECRET: random secret that signs the session cookie. MUST be
#   set and MUST differ from ADMIN_PASSWORD (login throws otherwise).
#   Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- Supabase (CMS data store) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- ImageKit (admin image/video uploads) ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# --- Site ---
# Canonical public URL (used for absolute links). Optional in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
